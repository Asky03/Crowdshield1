# =================================================================
# CrowdShield — .env.example
# =================================================================
# This file is SAFE TO COMMIT to git.
# It contains NO real secrets — only placeholder text.
#
# HOW TO USE:
#   Windows PowerShell:  copy .env.example .env
#   Mac / Linux:         cp .env.example .env
#
# Then open the new .env file and replace every placeholder
# with your real value. See comments for where to find each one.
# =================================================================

# -----------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------
PORT=5000
NODE_ENV=development

# -----------------------------------------------------------------
# SUPABASE  →  supabase.com → your project → Settings (gear) → API
# -----------------------------------------------------------------

# "Project URL" on the API settings page
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# "anon / public" key on the API settings page
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# "service_role / secret" key on the API settings page
# WARNING: Never expose this in frontend code
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE

# Settings → API → scroll down → "JWT Settings" → "Legacy JWT Secret" tab
SUPABASE_JWT_SECRET=YOUR_SUPABASE_JWT_SECRET_HERE

# -----------------------------------------------------------------
# AWS  →  console.aws.amazon.com → IAM → Users → crowdshield-backend
#          → Security credentials tab → Access keys
# WARNING: Use IAM user keys ONLY. Never use root account keys.
# -----------------------------------------------------------------

AWS_ACCESS_KEY_ID=YOUR_IAM_ACCESS_KEY_ID_HERE
AWS_SECRET_ACCESS_KEY=YOUR_IAM_SECRET_ACCESS_KEY_HERE

# The region where you created your S3 bucket
# Examples: us-east-1  eu-west-1  ap-south-1  us-west-2  ap-southeast-1
AWS_REGION=us-east-1

# AWS → S3 → your bucket name (copy exactly, case-sensitive)
AWS_S3_BUCKET=crowdshield-media

# AWS → SNS → Topics → crowdshield-alerts → copy the ARN at the top
AWS_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:YOUR_ACCOUNT_ID:crowdshield-alerts

# -----------------------------------------------------------------
# ML SERVICE  →  keep as-is for local development
# -----------------------------------------------------------------
ML_SERVICE_URL=http://localhost:8000
MAX_FILE_SIZE_MB=100
