{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "CrowdShieldS3Access",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject",
        "s3:HeadObject"
      ],
      "Resource": "arn:aws:s3:::crowdshield-media/*"
    },
    {
      "Sid": "CrowdShieldS3List",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::crowdshield-media"
    },
    {
      "Sid": "CrowdShieldSNSPublish",
      "Effect": "Allow",
      "Action": ["sns:Publish"],
      "Resource": "arn:aws:sns:*:*:crowdshield-alerts"
    }
  ]
}
